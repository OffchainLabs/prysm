  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Average JSON-RPC body size divided by average SSZ-over-HTTP body size. Each instance is averaged first, so a fleet with N JSON-RPC nodes and M SSZ-over-HTTP nodes is not weighted by node count.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "avg by (method, direction) (\n  (\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_sum{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"json-rpc\"}[$__rate_interval])\n    )\n    /\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"json-rpc\"}[$__rate_interval])\n    )\n  )\n  and on (instance, method, direction)\n  (\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"json-rpc\"}[$__rate_interval])\n    ) > 0\n  )\n)\n/\navg by (method, direction) (\n  (\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_sum{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"ssz-http\"}[$__rate_interval])\n    )\n    /\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"ssz-http\"}[$__rate_interval])\n    )\n  )\n  and on (instance, method, direction)\n  (\n    sum by (instance, method, direction) (\n      rate(engine_body_size_bytes_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", direction=~\"$direction\", transport=\"ssz-http\"}[$__rate_interval])\n    ) > 0\n  )\n)",
          "legendFormat": "{{method}} {{direction}} json-rpc/ssz-http",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Body Size Ratio, Equal Instance Weight",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "SSZ-over-HTTP fallback count divided by the number of selected instances that expose engine transport metrics.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(\n  sum(increase(engine_ssz_http_fallback_count{job=~\"$job\", instance=~\"$instance\"}[$__range]))\n  or vector(0)\n)\n/\nclamp_min(\n  count(count by (instance) (engine_request_latency_milliseconds_count{job=~\"$job\", instance=~\"$instance\"})),\n  1\n)",
          "legendFormat": "fallbacks per instance",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Fallbacks per Instance",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Engine call rate divided by the number of active instances for each transport.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
