            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum by (transport) (\n  rate(engine_request_latency_milliseconds_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", transport=~\"$transport\"}[$__rate_interval])\n)\n/\nclamp_min(\n  count by (transport) (\n    sum by (instance, transport) (\n      rate(engine_request_latency_milliseconds_count{job=~\"$job\", instance=~\"$instance\", method=~\"$method\", transport=~\"$transport\"}[$__rate_interval])\n    ) > 0\n  ),\n  1\n)",
          "legendFormat": "{{transport}}",
          "range": true,
          "refId": "A"
