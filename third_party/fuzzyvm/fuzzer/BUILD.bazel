load("@prysm//tools/go:def.bzl", "go_library", "go_test")

go_library(
    name = "fuzzer",
    srcs = [
        "corpus.go",
        "fuzzer.go",
    ],
    importpath = "github.com/MariusVanDerWijden/FuzzyVM/fuzzer",
    visibility = ["//visibility:public"],
    deps = [
        "//filler",
        "//generator",
        "@com_github_ethereum_go_ethereum//common",
        "@com_github_ethereum_go_ethereum//core/rawdb",
        "@com_github_ethereum_go_ethereum//core/vm",
        "@com_github_ethereum_go_ethereum//eth/tracers/logger",
        "@com_github_ethereum_go_ethereum//tests",
        "@com_github_holiman_goevmlab//fuzzing",
        "@com_github_korovkin_limiter//:limiter",
        "@org_golang_x_crypto//sha3",
    ],
